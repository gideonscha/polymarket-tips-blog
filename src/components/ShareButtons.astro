---
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;
const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(url);
---

<div class="flex items-center gap-3 my-6">
  <span class="text-slate-400 text-sm">Share:</span>
  <a
    href={`https://x.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}&via=PolymarketTips`}
    target="_blank"
    rel="noopener noreferrer"
    class="text-slate-400 hover:text-white no-underline text-sm flex items-center gap-1.5 bg-navy-light px-3 py-1.5 rounded-lg border border-slate-800 hover:border-slate-700"
  >
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
    </svg>
    Post on X
  </a>
</div>
