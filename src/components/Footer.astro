    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="text-center md:text-left">
        <a href="/" class="text-lg font-bold text-white hover:text-white no-underline">
          polymarket.<span class="text-amber-500">tips</span> <span class="text-slate-400 font-normal text-sm">blog</span>
        </a>
        <p class="text-slate-400 text-sm mt-1">Top trader intelligence for Polymarket</p>
      </div>
      <div class="flex items-center gap-6 text-sm">
        <a href="https://polymarket.tips" class="text-slate-400 hover:text-white no-underline">polymarket.tips</a>
        <a
          href="https://x.com/PolymarketTips"
          target="_blank"
