---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: 'https://polymarket.tips', label: 'Markets' },
  { href: 'https://polymarket.tips/traders', label: 'Traders' },
  { href: 'https://polymarket.tips/signals', label: 'Signals' },
  { href: '/category/polymarket-guides', label: 'About' },
];
---

<header class="border-b border-slate-800">
  <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="text-xl font-bold text-white hover:text-white no-underline">
      polymarket.<span class="text-amber-500">tips</span> <span class="text-slate-400 font-normal text-lg">blog</span>
    </a>
    <nav class="hidden md:flex items-center gap-6">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-slate-400 hover:text-white text-sm font-medium no-underline transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://polymarket.tips"
        class="bg-amber-500 hover:bg-amber-400 text-navy font-semibold text-sm px-4 py-2 rounded-lg no-underline transition-colors"
      >
        View Live Signals →
      </a>
    </nav>
    <button
      id="mobile-menu-btn"
      class="md:hidden text-slate-400 hover:text-white"
      aria-label="Toggle menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
  <nav id="mobile-menu" class="hidden md:hidden border-t border-slate-800 px-4 py-3">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="block py-2 text-slate-400 hover:text-white text-sm no-underline"
      >
        {link.label}
      </a>
    ))}
    <a
      href="https://polymarket.tips"
      class="block mt-2 bg-amber-500 hover:bg-amber-400 text-navy font-semibold text-sm px-4 py-2 rounded-lg no-underline text-center"
    >
      View Live Signals →
    </a>
  </nav>
</header>

<script>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
